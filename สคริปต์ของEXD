local function calculateSoundScore(sound)
    local score = 0
    if sound.Playing then score = score + 50 end
    if sound.TimeLength > 10 then score = score + 30 end
    local name = sound.Name:lower()
    if name:find("music") or name:find("song") or name:find("radio") then score = score + 20
    elseif name:find("engine") or name:find("wind") or name:find("tire") or name:find("walk") then score = score - 50 end
    return score
end

local function findSoundRecursive(parent)
    local bestSoundId = nil
    local maxScore = -100
    local success, descendants = pcall(function() return parent:GetDescendants() end)
    if not success or not descendants then return nil end
    for _, desc in pairs(descendants) do
        if desc:IsA("Sound") and desc.SoundId ~= "" and string.match(desc.SoundId, "%d+") then
            local score = calculateSoundScore(desc)
            if score > maxScore then
                maxScore = score
                bestSoundId = desc.SoundId
            end
        end
    end
    return bestSoundId
end

local function scanPlayer(player)
    currentTargetPlayer = player
    StatusLabel.Text = "กำลังสแกน..."
    StatusLabel.TextColor3 = Theme.Primary
    
    local foundSound = nil
    local sourceName = ""
    
    if player.Character then
        foundSound = findSoundRecursive(player.Character)
        if foundSound then sourceName = "ตัวละคร/วิทยุ" end
    end
    
    if not foundSound and player.Character then
        local humanoid = player.Character:FindFirstChild("Humanoid")
        if humanoid and humanoid.SeatPart then
            local seat = humanoid.SeatPart
            local vehicle = seat.Parent
            while vehicle.Parent and not vehicle.Parent:IsA("Workspace") do
                vehicle = vehicle.Parent
            end
            foundSound = findSoundRecursive(vehicle)
            if foundSound then sourceName = "ยานพาหนะ" end
        end
    end
    
    if not foundSound and player.Backpack then
        foundSound = findSoundRecursive(player.Backpack)
        if foundSound then sourceName = "กระเป๋า" end
    end

    if foundSound then
        updateDisplay(foundSound, "✅ เจอไอดีเพลงเเล้ว!", sourceName)
        StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    else
        StatusLabel.Text = "ไม่พบเพลง"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        SourceLabel.Text = "-"
        updateDisplay("", "ไม่พบเพลง", "-")
    end
end

local function createPlayerButton(player)
    local btn = Instance.new("TextButton")
    btn.Name = player.Name
    btn.Parent = PlayerListFrame 
    btn.BackgroundColor3 = Theme.Button
    btn.BackgroundTransparency = 0.5
    btn.Size = UDim2.new(1, -5, 0, 40)
    btn.Font = Enum.Font.GothamMedium
    btn.Text = "  " .. player.Name
    btn.TextColor3 = Theme.Text
    btn.TextSize = 14
    btn.TextXAlignment = Enum.TextXAlignment.Left
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = btn
    
    btn.MouseButton1Click:Connect(function()
        for _, child in pairs(PlayerListFrame:GetChildren()) do
            if child:IsA("TextButton") then
                child.BackgroundColor3 = Theme.Button
                child.TextColor3 = Theme.Text
            end
        end
        btn.BackgroundColor3 = Theme.Primary
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        scanPlayer(player)
    end)
end

local function refreshList()
    for _, child in pairs(PlayerListFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    for _, player in pairs(Players:GetPlayers()) do
        createPlayerButton(player)
    end
end

Players.PlayerAdded:Connect(refreshList)
Players.PlayerRemoving:Connect(refreshList)

local function performSearch()
    local text = SearchInput.Text:gsub("^%s*(.-)%s*$", "%1")
    if text == "" then return end
    local searchName = text:lower()
    local foundPlayer = nil
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():find(searchName) or p.DisplayName:lower():find(searchName) then
            foundPlayer = p
            break
        end
    end
    
    if foundPlayer then
        scanPlayer(foundPlayer)
    else
        StatusLabel.Text = "ไม่พบ: " .. text
        StatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
    end
end

SearchBtn.MouseButton1Click:Connect(performSearch)
SearchInput.FocusLost:Connect(function(enter) if enter then performSearch() end end)

