local isOpen = false
local function toggleUI()
    isOpen = not isOpen
    if isOpen then
        MainFrame.Visible = true
        local centerX = SavedPosition.X.Offset + 300
        local centerY = SavedPosition.Y.Offset + 200
        MainFrame.Size = UDim2.new(0, 0, 0, 0)
        MainFrame.Position = UDim2.new(SavedPosition.X.Scale, centerX, SavedPosition.Y.Scale, centerY)
        TweenService:Create(MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 600, 0, 400),
            Position = SavedPosition 
        }):Play()
    else
        SavedPosition = MainFrame.Position
        local centerCurrentX = MainFrame.Position.X.Offset + 300
        local centerCurrentY = MainFrame.Position.Y.Offset + 200
        local tween = TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(MainFrame.Position.X.Scale, centerCurrentX, MainFrame.Position.Y.Scale, centerCurrentY)
        })
        tween:Play()
        tween.Completed:Connect(function()
            if not isOpen then MainFrame.Visible = false end
        end)
        previewSound:Stop()
    end
end

