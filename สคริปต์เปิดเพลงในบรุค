-- Slider Logic
local volDragging = false
volBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then volDragging = true end
end)
UserInputService.InputChanged:Connect(function(input)
	if volDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local percent = math.clamp((input.Position.X - volBar.AbsolutePosition.X) / volBar.AbsoluteSize.X, 0, 1)
		volFill.Size = UDim2.new(percent, 0, 1, 0)
		currentVolume = percent * 2
		volText.Text = math.floor(percent * 200) .. "%"
	end
end)
UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then volDragging = false end
end)

local pitchDragging = false
pitchBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then pitchDragging = true end
end)
UserInputService.InputChanged:Connect(function(input)
	if pitchDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local percent = math.clamp((input.Position.X - pitchBar.AbsolutePosition.X) / pitchBar.AbsoluteSize.X, 0, 1)
		pitchFill.Size = UDim2.new(percent, 0, 1, 0)
		currentPitch = 0.5 + (percent * 1.5)
		pitchText.Text = string.format("%.2f x", currentPitch)
	end
end)
UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then pitchDragging = false end
end)

